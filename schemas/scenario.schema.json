{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scenario.schema.json",
  "title": "ClawPilot Scenario Schema",
  "description": "Schema for a single evaluation scenario in the ClawPilot SMB Skills Scientific Workflow Study",
  "type": "object",
  "required": [
    "scenario_id",
    "workflow_id",
    "workflow_name",
    "seed",
    "tier",
    "intent",
    "persona",
    "fixture_id",
    "user_message",
    "expected_routing",
    "expected_output_shape",
    "success_rubric",
    "judge_instructions"
  ],
  "properties": {
    "scenario_id": {
      "type": "string",
      "pattern": "^WF-[0-9]{2}-[0-9]{5}$",
      "description": "Format: WF-XX-NNNNN where XX is workflow number and NNNNN is zero-padded sequence"
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^WF-[0-9]{2}$"
    },
    "workflow_name": {
      "type": "string"
    },
    "seed": {
      "type": "integer",
      "description": "Reproducibility seed for the generation call"
    },
    "tier": {
      "type": "integer",
      "enum": [1, 2, 3, 4]
    },
    "intent": {
      "type": "string",
      "enum": ["happy", "adherence", "assumption-stress", "design-redesign"]
    },
    "targeted_failure_mode": {
      "type": ["string", "null"],
      "pattern": "^FM-WF[0-9]{2}-[A-Z]+$",
      "description": "Null for happy-path; FM code for failure-targeting scenarios"
    },
    "persona": {
      "type": "string",
      "enum": ["CSA", "DSSP", "Manager"]
    },
    "fixture_id": {
      "type": "string",
      "pattern": "^FX-[0-9]{3}$"
    },
    "user_message": {
      "type": "string",
      "description": "What the user types or how the automation is triggered"
    },
    "input_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "content"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "email_thread",
              "transcript",
              "calendar_event",
              "msx_record",
              "document",
              "spa_signal",
              "none"
            ]
          },
          "content": {
            "description": "String for text inputs, object for structured inputs"
          },
          "metadata": {
            "type": "object",
            "properties": {
              "freshness": {
                "type": "string",
                "format": "date-time"
              },
              "source": {
                "type": "string"
              },
              "speaker_attribution": {
                "type": "string",
                "enum": ["named", "numbered", "mixed", "absent"]
              },
              "length_class": {
                "type": "string",
                "enum": ["short", "medium", "long"]
              }
            }
          }
        }
      }
    },
    "perturbations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Identifiers from perturbation library"
    },
    "expected_routing": {
      "type": "object",
      "required": ["entry_skill", "modules"],
      "properties": {
        "entry_skill": {
          "type": "string"
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "handoffs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["target_skill", "condition"],
            "properties": {
              "target_skill": {
                "type": "string"
              },
              "condition": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "expected_output_shape": {
      "type": "object",
      "required": ["template", "required_artifacts"],
      "properties": {
        "template": {
          "type": "string"
        },
        "required_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "write_proposals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "record_type",
              "record_id",
              "field_name",
              "current_value",
              "proposed_value",
              "must_require_approval"
            ],
            "properties": {
              "record_type": {
                "type": "string",
                "enum": [
                  "opportunity",
                  "milestone",
                  "contact",
                  "account",
                  "forecast_record"
                ]
              },
              "record_id": {
                "type": "string"
              },
              "field_name": {
                "type": "string"
              },
              "current_value": {},
              "proposed_value": {},
              "evidence_source": {
                "type": "string"
              },
              "must_require_approval": {
                "type": "boolean",
                "const": true
              }
            }
          }
        }
      }
    },
    "success_rubric": {
      "type": "object",
      "required": [
        "usability_anchors",
        "evidence_anchors",
        "decision_anchors"
      ],
      "properties": {
        "usability_anchors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 3,
          "description": "Concrete anchors for 0-5 scoring. Provide examples that earn 5, 3, and 1."
        },
        "evidence_anchors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 3
        },
        "decision_anchors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 3
        }
      }
    },
    "guardrail_checks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Specific guardrails this scenario probes"
    },
    "judge_instructions": {
      "type": "object",
      "required": ["scoring_mode"],
      "properties": {
        "scoring_mode": {
          "type": "string",
          "enum": [
            "standard",
            "guardrail-neutral",
            "verdict-on-structural"
          ]
        },
        "verdict_required_axes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["routing", "evidence", "guardrail"]
          },
          "description": "Only present when scoring_mode = verdict-on-structural"
        }
      }
    }
  }
}
